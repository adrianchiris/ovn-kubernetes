apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  labels:
    prometheus: k8s
    role: alert-rules
  name: ovnkube-rules
  namespace: ovn-kubernetes
spec:
  groups:
  - name: general.rules
    rules:
    - alert: OvnKubeNoRunningManager
      expr: absent(up{job="ovnkube-master", namespace="ovn-kubernetes"} == 1)
      for: 4m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: There is no running ovnkube-manager

    - alert: OvnKubeManagerMultipleLeaders
      expr: sum(ovnkube_master_leader) > 1
      for: 4m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: There are multiple ovnkube-manager leaders

    - alert: OvnKubeManagerNoLeader
      expr: max(ovnkube_master_leader) == 0
      for: 4m
      labels:
        severity: critical
        pduuid: P2AR7UQ
      annotations:
       message: There is no running ovnkube-manager leader

    - alert: OvnKubePodRestarts
      expr: |
        rate(kube_pod_container_status_restarts_total{namespace="ovn-kubernetes", container=~"ovnkube.*"}[15m]) * 60 * 5 > 0
      for: 30m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} {{ $labels.container}} is restarting 
         {{ printf "%.2f" $value }} times / 5 minutes.        
                
    - alert: K8sNodeWithoutOvnKubeAgentRunning
      expr: |
        kube_node_info unless on(node)
        (kube_pod_info{namespace="ovn-kubernetes", pod=~"ovnkube-node.*"}) > 0
      for: 10m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         All K8s nodes should be running OVN K8s Agent pods, 
         but OVN K8s Agent pod is not running on {{ $labels.node }} node.  

    - alert: K8sNodesWithoutOvnNBDBPod
      expr: |
        kube_node_info{node=~"k8s-ovn-0.*"} unless on(node) 
        (kube_pod_info{namespace="ovn-kubernetes", pod=~"ovn-nbdb-.*"}) > 0
      for: 10m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         The OVN DB nodes k8s-ovn-01, k8s-ovn-02, and k8s-ovn-03 should be running OVN NB DB Pods,
         but OVN NB DB Pod is not running on {{ $labels.node }} node.

    - alert: K8sNodesWithoutOvnSBDBPod
      expr: |
        kube_node_info{node=~"k8s-ovn-0.*"} unless on(node) 
        (kube_pod_info{namespace="ovn-kubernetes", pod=~"ovn-sbdb-.*"}) > 0
      for: 10m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         The OVN DB nodes k8s-ovn-01, k8s-ovn-02, and k8s-ovn-03 should be running OVN NB DB Pods, 
         but OVN SB DB Pod is not running on {{ $labels.node }} node.

    - alert: K8sNodeWithoutOvnNorthPod
      expr: |
        kube_node_info{node=~"ngn-master-.*"} unless on(node) 
        (kube_pod_info{namespace="ovn-kubernetes", pod=~"ovn-north-.*"}) > 0
      for: 10m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         The NGN master nodes ngn-master-01, ngn-master-02, and ngn-master-03 
         should be running ovn-north pods, but ovn-north pod is not running on 
         {{ $labels.node }} node.

    - alert: K8sNodeWithoutOvnKubeManagerPod
      expr: |
        kube_node_info{node=~"ngn-master-.*"} unless on(node) 
        (kube_pod_info{namespace="ovn-kubernetes", pod=~"ovnkube-master-.*"}) > 0
      for: 10m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         The NGN master nodes ngn-master-01, ngn-master-02, and ngn-master-03 
         should be running ovnkube-manager pod, but ovnkube-manager pod is not 
         running on {{ $labels.node }} node.

    - alert: OvnKubeHighPodCreationLatency99thPercentile
      expr: |
        histogram_quantile(0.99,
         sum by (le) (
           rate(ovnkube_master_pod_creation_latency_seconds_bucket[15m])
         ) 
        ) > 5
      for: 10m
      labels:
       severity: major
       pduuid: P2AR7UQ
      annotations:
       message: |
         The pod creation latency value {{ $value }} aggregated across 
         all masters for the last 15minutes is more than 5 seconds.

    - alert: OvnKubeIncreaseInPodCreationLatency99thPercentile
      expr: |
        histogram_quantile(0.99,
         sum by (le) ( 
          rate(ovnkube_master_pod_creation_latency_seconds_bucket[15m] 
          offset 15m)
         )
        )
        -
        histogram_quantile(0.99,
         sum by (le) (
          rate(ovnkube_master_pod_creation_latency_seconds_bucket[15m])
         )
        ) > 5 
     
      for: 10m
      labels:
       severity: major
       pduuid: P2AR7UQ
      annotations:
       message: |
         The pod creation latency aggregated across all masters for the last 
         15minutes is more than 5 seconds as compared to 15 minutes before last 15 minutes.

    - alert: OvnKubeHighNBCliLatency99thPercentile
      expr: |
        histogram_quantile(0.99,
          sum by (le) (
            rate(ovnkube_master_ovn_cli_latency_seconds_bucket{
              command="ovn-nbctl"}[15m])
          )
        ) > 3 
      for: 10m
      labels:
       severity: major
       pduuid: P2AR7UQ
      annotations:
       message: |
         The ovn-nbctl 99th percentile CLI latency {{ value }} aggregated 
         across all masters for the last 15minutes is more than 3 seconds.

    - alert: OvnKubeHighSBCliLatency99thPercentile
      expr: |
        histogram_quantile(0.99,
          sum by (le) (
            rate(ovnkube_master_ovn_cli_latency_seconds_bucket{
              command="ovn-sbctl"}[15m])
          )
        ) > 3
      for: 10m
      labels:
       severity: major
       pduuid: P2AR7UQ
      annotations:
       message: |
         The ovn-sbctl 99th percentile CLI latency {{ value }} aggregated
         across all masters for the last 15minutes is more than 3 seconds.

    - alert: OvnKubeHighK8sNetworkPolicyUpdateLatency99thPercentile
      expr: |
        histogram_quantile(0.99,
          sum by (le) (
            rate(ovnkube_master_resource_update_latency_seconds_bucket{
              name="NetworkPolicy"}[15m])
          )
        ) > 1
      for: 10m
      labels:
       severity: major
       pduuid: P2AR7UQ
      annotations:
       message: |
         The 99th percentile {{ $labels.name }} update latency {{ value }} aggregated 
         across all masters for the last 15minutes is more than 1 seconds.

    - alert: OvnKubeHighK8sNamespaceUpdateLatency99thPercentile
      expr: |
        histogram_quantile(0.99,
          sum by (le) (
            rate(ovnkube_master_resource_update_latency_seconds_bucket{
              name="Namespace"}[15m])
          )
        ) > 1
      for: 10m
      labels:
       severity: major
       pduuid: P2AR7UQ
      annotations:
       message: |
         The 99th percentile {{ $labels.name }} update latency {{ value }} 
         aggregated across all masters for the last 15minutes is more than 1 seconds.

    - alert: OvnKubeHighK8sServiceUpdateLatency99thPercentile
      expr: |
        histogram_quantile(0.99,
          sum by (le) (
            rate(ovnkube_master_resource_update_latency_seconds_bucket{
              name="Service"}[15m])
          )
        ) > 1
      for: 10m
      labels:
       severity: major
       pduuid: P2AR7UQ
      annotations:
       message: |
         The 99th percentile {{ $labels.name }} update latency {{ value }} aggregated 
         across all masters for the last 15minutes is more than 1 seconds.

    - alert: OvnKubeHighK8sEndpointUpdateLatency99thPercentile
      expr: |
        histogram_quantile(0.99,
          sum by (le) (
            rate(ovnkube_master_resource_update_latency_seconds_bucket{
              name="Endpoint"}[15m])
          )
        ) > 1
      for: 10m
      labels:
       severity: major
       pduuid: P2AR7UQ
      annotations:
       message: |
         The 99th percentile {{ $labels.name }} update latency {{ value }} aggregated
         across all masters for the last 15minutes is more than 1 seconds.

    - alert: OvnKubeNodeLogFileSize
      expr: |
        rate(ovnkube_node_logfile_size{namespace="ovn-kubernetes", job="ovnkube-node"}[15m]) * 5 * 60 / 1024 / 1024 > 1
      for: 10m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} {{ $labels.logfile_name }} file size is
         increasing {{ printf "%.2f" $value }} Mb / 5 minutes

    - alert: OvnKubeMasterLogFileSize
      expr: |
        rate(ovnkube_master_logfile_size{namespace="ovn-kubernetes", job="ovnkube-master"}[15m]) * 5 * 60 / 1024 / 1024 > 1
      for: 10m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} {{ $labels.logfile_name }} file size is
         increasing {{ printf "%.2f" $value }} Mb / 5 minutes

    - alert: OvnNBDBStale
      expr: time() - max(ovnkube_master_nb_e2e_timestamp) > 120
      for: 4m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         ovn-kubernetes has not written anything to the northbound database for too long

    - alert: OvnSBDBStale
      expr: max(ovnkube_master_nb_e2e_timestamp) - max(ovnkube_master_sb_e2e_timestamp) > 120
      for: 4m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         ovn-northd has not successfully synced changes from northbound DB 
         to the southbound DB for too long

    - alert: OvnNBDBContainerRestarts
      expr: |
        rate(kube_pod_container_status_restarts_total{namespace="ovn-kubernetes", container="nbdb"}[15m]) * 60 * 5 > 0
      for: 30m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} nbdb container is 
         restarting {{ printf "%.2f" $value }} times / 5 minutes

    - alert: OvnSBDBContainerRestarts
      expr: |
        rate(kube_pod_container_status_restarts_total{namespace="ovn-kubernetes", container="sbdb"}[15m]) * 60 * 5 > 0
      for: 30m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} sbdb container is 
         restarting {{ printf "%.2f" $value }} times / 5 minutes.

    - alert: OvnNBDBMultipleLeaders
      expr: sum(ovn_db_cluster_server_role{db_name="OVN_Northbound",server_role="leader"}) > 1
      for: 4m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: There are multiple ovn-nbdb leaders

    - alert: OvnNBDBNoLeader
      expr: max(ovn_db_cluster_server_role{db_name="OVN_Northbound",server_role="leader"}) == 0
      for: 4m
      labels:
        severity: critical
        pduuid: P2AR7UQ
      annotations:
       message: There is no running ovn-nbdb leader

    - alert: OvnSBDBMultipleLeaders
      expr: sum(ovn_db_cluster_server_role{db_name="OVN_Southbound",server_role="leader"}) > 1
      for: 4m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: There are multiple ovn-sbdb leaders

    - alert: OvnSBDBNoLeader
      expr: max(ovn_db_cluster_server_role{db_name="OVN_Southbound",server_role="leader"}) == 0
      for: 4m
      labels:
        severity: critical
        pduuid: P2AR7UQ
      annotations:
       message: There is no running ovn-sbdb leader

    - alert: OvnDbDBSize
      expr: |
        rate(ovn_db_db_size{namespace="ovn-kubernetes", job="ovnkube-node"}[15m]) * 5 * 60 / 1024 / 1024 > 1
      for: 10m
      labels:
        severity: warning
        pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} {{ $labels.db_name }} size is increasing
         {{ printf "%.2f" $value }} MB / 5 minutes

    - alert: OvnNorthdContainerRestarts
      expr: |
        rate(kube_pod_container_status_restarts_total{namespace="ovn-kubernetes", container="ovn-northd"}[15m]) * 60 * 5 > 0
      for: 30m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovn-northd container is 
         restarting {{ printf "%.2f" $value }} times / 5 minutes

    - alert: OvnNorthdNotActive
      expr: sum(ovn_northd_status) != 1
      for: 4m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: There is no running ovn-northd.

    - alert: OvnNorthdTxnError
      expr: |
        rate(ovn_northd_txn_error{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 0
      for: 10m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovn-northd containers
         transaction error is {{ printf "%.2f" $value }} per second

    - alert: OvnNorthdTxnIncomplete
      expr: |
        rate(ovn_northd_txn_incomplete{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 1
      for: 30m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovn-northd containers
         transaction incomplete is {{ printf "%.2f" $value }} per second.

    - alert: OvnControllerContainerRestarts
      expr: |
        rate(kube_pod_container_status_restarts_total{namespace="ovn-kubernetes", 
        container="ovn-controller"}[15m]) * 60 * 5 > 0
      for: 30m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovn-controller container 
         is restarting {{ printf "%.2f" $value }} times / 5 minutes

    - alert: OvnControllerTxnError
      expr: |
        rate(ovn_controller_txn_error{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 0
      for: 10m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovn-controller containers
         transaction error is {{ printf "%.2f" $value }} per second.

    - alert: OvnControllerTxnIncomplete
      expr: |
        rate(ovn_controller_txn_incomplete{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 1
      for: 30m
      labels:
       severity: critical
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovn-controller containers
         transaction incomplete is {{ printf "%.2f" $value }} per second

    - alert: OvnControllerLflowRun
      expr: |
        rate(ovn_controller_lflow_run{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 0
      for: 10m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovn-controller containers
         logical flow table translation is {{ printf "%.2f" $value }} per second.
       
    - alert: OvnControllerLowerGenevePortCount
      expr: |
        ovn_controller_integration_bridge_geneve_ports_total and kube_node_info and
        (ovn_controller_integration_bridge_geneve_ports_total{job="ovnkube-node", namespace="ovn-kubernetes"} 
        != scalar(count(kube_node_info)) - 1)
      for: 10m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         The list of nodes that have a lower number of Geneve Ports
         and counts they have 
         {{ range query "ovn_controller_integration_bridge_geneve_ports_total{job='ovnkube-node', namespace='ovn-kubernetes'} !=  scalar(count(kube_node_info)) - 1" }}
         {{ .Labels.instance }}: {{ .Value }}
         {{ end }}.

    - alert: OvsDBdbSize
      expr: |
        rate(ovs_ovsdb_db_size{namespace="ovn-kubernetes", job="ovnkube-node"}[15m]) * 5 * 60 / 1024 / 1024 > 1
      for: 10m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovs-db size is increasing
         {{ printf "%.2f" $value }} Mb / 5 minutes

    - alert: OvsVswitchdDPFlowsLookupLost
      expr: |
        rate(ovs_vswitchd_dp_flows_lookup_missed{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 1000
      for: 15m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovs-vswitchd process reports that
         number of dropped packets that match DP flows is {{ printf "%.2f" $value }} per second.

    - alert: OvsVswitchdDPFlowsLookupMissed
      expr: |
        rate(ovs_vswitchd_dp_flows_lookup_missed{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 1000
      for: 15m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovs-vswitchd process reports that
         number of dropped packets that not-matching DP flows is {{ printf "%.2f" $value }} per second.

    - alert: OvsVswitchdInterfaceRxErrors
      expr: |
        rate(ovs_vswitchd_interface_rx_errors{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 100
      for: 15m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovs-vswitchd process reports that total
         number of packets with errors received by OVS interface is {{ printf "%.2f" $value }} per second.

    - alert: OvsVswitchdInterfaceTxErrors
      expr: |
        rate(ovs_vswitchd_interface_tx_errors{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 100
      for: 15m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovs-vswitchd process reports that total
         number of packets with errors transmitted by OVS interface is {{ printf "%.2f" $value }} per second.

    - alert: OvsVswitchdPacketInDrop
      expr: |
        rate(ovs_vswitchd_packet_in_drop{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 100
      for: 15m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovs-vswitchd process reports that
         number of packets that dropped due to resource constraints is {{ printf "%.2f" $value }} per second.

    - alert: OvsVswitchdBridgeFlowsTotal
      expr: |
        max(ovs_vswitchd_bridge_flows_total{namespace="ovn-kubernetes",job="ovnkube-node"}) > 350000
      for: 15m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovs-vswitchd process reports that
         number of Bridge flows on the OVS bridge is {{ printf "%.2f" $value }}.

    - alert: OvsVswitchdDPFlowsTotal
      expr: |
        max(ovs_vswitchd_dp_flows_total{namespace="ovn-kubernetes",job="ovnkube-node"}) > 10000
      for: 15m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovs-vswitchd process reports that
         number of DP flows is {{ printf "%.2f" $value }}.

    - alert: OvsVswitchdOfprotoRecvOpenflow
      expr: |
        rate(ovs_vswitchd_ofproto_recv_openflow{namespace="ovn-kubernetes",job="ovnkube-node"}[1m]) > 50
      for: 15m
      labels:
       severity: warning
       pduuid: P2AR7UQ
      annotations:
       message: |
         Pod ovn-kubernetes/ {{ $labels.pod }} ovs-vswitchd process reports that
         number of handled flows is {{ printf "%.2f" $value }} per second for longer than 15 mins.
